# ============================================================
# BOFH Bot - Variables de entorno para testing local
# Copiar este archivo como .env y completar los valores
# ============================================================

# Token del bot de Discord (obtenerlo en Discord Developer Portal)
BOT_token=TU_TOKEN_DE_DISCORD_ACA

# ID del servidor (guild) de prueba
# Activar modo desarrollador en Discord: Ajustes > App > Modo desarrollador
# Luego click derecho en el servidor > Copiar ID del servidor
guild_id=ID_DEL_SERVIDOR

# ID del canal donde va el feed RSS de ShitHappens
shitChannel=ID_DEL_CANAL

# ID del canal donde se publican ofertas de trabajo
JobsChannel=ID_DEL_CANAL

# ID del canal general de Sysarmy
SysarmyChannel=ID_DEL_CANAL

# ID del canal de administracion de jobs
JobsAdminChannel=ID_DEL_CANAL

# ID del Bridge Bot de Discord (si usas un bridge bot, sino dejarlo vacio)
bridgebotID=

# --- APIs opcionales (comentar si no se van a testear esas features) ---

# API Key de OpenWeatherMap (para comando /clima)
WEATHER_key=

# API Key de Google/YouTube (para comando /nerdearla)
google_key=

# API Key de TfL Londres (para comando /underground)
TFL_key=

# Credenciales API Subte BA (para comando /subte)
SUBTE_clientID=
SUBTE_clientSecret=

# Google Drive / Sheets para importacion de jobs via Google Form
jobs_gdrive_service=
jobs_sheetid=
jobs_sheetname=Respuestas

# API Key de api-football / api-sports (para comandos de futbol)
APISPORTS_KEY=
